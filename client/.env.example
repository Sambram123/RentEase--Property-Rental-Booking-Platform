# ─── API Endpoint ─────────────────────────────────────────────────────────────
# Development: http://localhost:5000/api  (Vite dev proxy also works with /api)
# Production:  https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# ─── Razorpay (Public Key — safe to expose in frontend) ───────────────────────
VITE_RAZORPAY_KEY_ID=

# ─── Google Maps ──────────────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Get from Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── App Config ───────────────────────────────────────────────────────────────
VITE_APP_NAME=RentEase
VITE_APP_VERSION=1.0.0

# ─── Production Checklist ─────────────────────────────────────────────────────
# [ ] VITE_API_URL → production backend URL
# [ ] VITE_RAZORPAY_KEY_ID → Live Razorpay key
# [ ] All Firebase keys set to production project
# [ ] Run: npm run build
# [ ] Verify dist/ output before deploying
