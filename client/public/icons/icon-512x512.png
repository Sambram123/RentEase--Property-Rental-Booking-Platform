<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff385c;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e31c5f;stop-opacity:1" />
    </linearGradient>
    <clipPath id="rounded">
      <rect width="512" height="512" rx="113" ry="113"/>
    </clipPath>
  </defs>
  <rect width="512" height="512" rx="113" ry="113" fill="url(#bg)"/>
  <!-- House icon -->
  <g transform="translate(256, 256)" fill="white" opacity="0.95">
    <!-- Roof -->
    <polygon points="-163.84,-10.24 0,-163.84 163.84,-10.24" />
    <!-- Chimney -->
    <rect x="51.2" y="-184.32" width="40.96" height="61.44" rx="1"/>
    <!-- Wall -->
    <rect x="-138.24" y="-10.24" width="276.48" height="163.84" rx="10.24"/>
    <!-- Door -->
    <rect x="-35.84" y="61.44" width="71.68" height="92.16" rx="10.24" fill="rgba(255,56,92,0.4)"/>
    <!-- Windows -->
    <rect x="-102.4" y="20.48" width="51.2" height="51.2" rx="5.12" fill="rgba(255,56,92,0.35)"/>
    <rect x="51.2" y="20.48" width="51.2" height="51.2" rx="5.12" fill="rgba(255,56,92,0.35)"/>
  </g>
</svg>