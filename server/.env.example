# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Development:  mongodb://127.0.0.1:27017/rentease-dev
# Production:   mongodb+srv://<user>:<password>@cluster.mongodb.net/rentease
MONGO_URI=mongodb://127.0.0.1:27017/rentease-dev

# ─── Authentication ───────────────────────────────────────────────────────────
# MUST be changed in production — use a 64-char random string
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Development: http://localhost:5173
# Production:  https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ─── Razorpay Payments ────────────────────────────────────────────────────────
# Settings → API Keys — use Test Mode keys for development
# Production:  use Live Mode keys (keep RAZORPAY_SECRET server-side ONLY)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log files are written to /server/logs/
# combined.log — all log levels
# error.log    — errors only

# ─── Production Checklist ─────────────────────────────────────────────────────
# [ ] NODE_ENV=production
# [ ] MONGO_URI → production Atlas URI
# [ ] JWT_SECRET → 64+ char random string
# [ ] CLIENT_URL → deployed frontend URL (Vercel)
# [ ] RAZORPAY_KEY_ID / RAZORPAY_SECRET → Live keys
# [ ] CLOUDINARY_CLOUD_NAME / API_KEY / API_SECRET → production Cloudinary account
# [ ] Ensure /server/logs is writable

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get credentials at: https://cloudinary.com/console
# Images are stored in: RentEase/Properties/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

